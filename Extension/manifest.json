{
  "manifest_version": 3,
  "name": "DexManager Log Analyzer",
  "version": "2.0",
  "description": "Smart log analyzer with syntax highlighting, filtering, and Gemini AI.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Configurar Analizador con Gemini",
    "default_popup": "popup/popup.html",
    "default_icon": "images/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/shield.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "resume.txt"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}