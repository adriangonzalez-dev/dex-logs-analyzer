{
  "manifest_version": 3,
  "name": "DexManager Log Analyzer AI",
  "version": "1.0",
  "description": "Smart log analyzer with syntax highlighting, filtering, and Gemini AI.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Configurar Analizador con Gemini",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "resume.txt"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}